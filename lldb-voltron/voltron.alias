export PATH="/Users/macos/Library/Python/2.7/bin:$PATH"
alias vr="voltron view r"
alias vd="voltron view d"
alias vs="voltron view s --reverse"
alias vm="voltron view m"
alias tel="voltron view m -d -a"
alias telr="voltron view m -d -r"
alias vvv="tmuxinator start voltron"
alias vve="tmuxinator edit voltron"
